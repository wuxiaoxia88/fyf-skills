# ChatGPT Web Image skill environment example

# Optional: Chrome executable path
CHATGPT_IMAGE_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Required: Chrome remote debugging port
CHATGPT_IMAGE_DEBUG_PORT=9222

# Optional: dedicated Chrome profile directory for ChatGPT automation
CHATGPT_IMAGE_USER_DATA_DIR=$HOME/.chatgpt-image-skill-chrome

# Optional: output directory for downloaded/generated images
CHATGPT_IMAGE_OUTPUT_DIR=$HOME/.chatgpt-image-skill-output

# Optional: page URL
CHATGPT_IMAGE_PAGE_URL=https://chatgpt.com/

# Optional: probe timeout (ms)
CHATGPT_IMAGE_PROBE_TIMEOUT_MS=15000

# Optional: generation timeout (ms)
CHATGPT_IMAGE_GENERATION_TIMEOUT_MS=180000

# Optional: download timeout (ms)
CHATGPT_IMAGE_DOWNLOAD_TIMEOUT_MS=30000

# Optional: polling interval while waiting for generation (ms)
CHATGPT_IMAGE_POLL_INTERVAL_MS=3000
